# Copy to `.env` for local dev. Both vars are optional.

# URL of the deployed tutor-proxy Worker (see /worker/README.md). The browser
# talks ONLY to this Worker; the Anthropic API key lives only as a Worker secret
# and is never in the frontend bundle or this repo.
# Leave unset to run the app with the AI tutor disabled (phases 1–4 still work).
VITE_TUTOR_WORKER_URL=https://ankibot-tutor.ryanbohluli.workers.dev

# GA4 measurement ID for the ankibot analytics property. Not a secret — it's a
# public client-side ID. Set this ONLY in the production build environment so
# local dev / preview builds don't report to the live property. Leave it unset
# locally (analytics simply no-ops).
VITE_GA_MEASUREMENT_ID=G-DX3NH2067B
